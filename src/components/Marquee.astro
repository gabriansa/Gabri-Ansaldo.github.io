---
export interface Props {
  items: string[];
}
const { items } = Astro.props;
const doubled = [...items, ...items];
---

<div class="marquee" aria-hidden="true">
  <div class="marquee__track">
    {doubled.map((item) => (
      <>
        <span class="marquee__item">{item}</span>
        <span class="marquee__dot"></span>
      </>
    ))}
  </div>
</div>
