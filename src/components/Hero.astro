---
---

<section class="hero">
  <div class="wrap hero__inner">
    <div class="hero__meta reveal">
      <span class="eyebrow">Product Manager · San Francisco / Amsterdam</span>
      <span class="hero__clock" id="hero-clock"></span>
    </div>

    <h1 class="hero__title reveal">
      <span class="hero__line">I help build</span>
      <span class="hero__line"><span class="serif-italic">AI products</span></span>
      <span class="hero__line">that <span class="hero__highlight">ship</span>—</span>
      <span class="hero__line hero__line--small">and that people can actually trust.</span>
    </h1>

    <div class="hero__bottom reveal">
      <p class="hero__lede">
        Product Manager working on generative AI.
        Most recently at <strong>Motorola Solutions</strong> on a body-worn camera portfolio.
        On the side, building multi-agent systems like
        <a href="https://tryinvesti.co" target="_blank" rel="noopener noreferrer" class="link-underline">Investi</a>
        and <a href="/work/agentspeak/" class="link-underline">AgentSpeak</a>—mostly to keep learning.
      </p>
      <div class="hero__actions">
        <a href="#work" class="btn">
          Selected Work
          <span class="arrow" aria-hidden="true">↓</span>
        </a>
        <a href="#contact" class="btn btn-ghost">
          Get in touch
          <span class="arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: clamp(7rem, 14vw, 11rem) 0 clamp(3rem, 6vw, 5rem);
    position: relative;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 6vw, 4.5rem);
  }

  .hero__meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .hero__clock {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--mute);
    font-variant-numeric: tabular-nums;
  }

  .hero__title {
    font-family: 'Inter Tight', sans-serif;
    font-weight: 500;
    font-size: clamp(3rem, 13vw, 11.5rem);
    line-height: 0.92;
    letter-spacing: -0.045em;
    margin: 0;
    color: var(--ink);
  }

  .hero__line {
    display: block;
  }

  .hero__line--small {
    font-family: 'Instrument Serif', ui-serif, Georgia, serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.6rem, 4.5vw, 3.6rem);
    color: var(--mute);
    margin-top: clamp(0.6rem, 1.6vw, 1.2rem);
    letter-spacing: -0.02em;
  }

  .hero__highlight {
    position: relative;
    color: var(--accent);
  }

  .hero__highlight::after {
    content: '';
    position: absolute;
    left: -2%;
    right: -2%;
    bottom: 6%;
    height: 0.18em;
    background: var(--accent);
    opacity: 0.18;
    border-radius: 4px;
    z-index: -1;
  }

  .hero__bottom {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: end;
    padding-top: clamp(2rem, 4vw, 3.5rem);
    border-top: 1px solid var(--hairline);
  }

  @media (max-width: 820px) {
    .hero__bottom {
      grid-template-columns: 1fr;
    }
  }

  .hero__lede {
    font-size: clamp(1.05rem, 1.5vw, 1.25rem);
    line-height: 1.55;
    color: var(--ink);
    max-width: 56ch;
    margin: 0;
  }

  .hero__lede strong {
    font-weight: 500;
  }

  .hero__actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  @media (max-width: 820px) {
    .hero__actions {
      justify-content: flex-start;
    }
  }
</style>

<script>
  function renderClock() {
    const el = document.getElementById('hero-clock');
    if (!el) return;
    const fmt = (tz: string) =>
      new Intl.DateTimeFormat('en-GB', {
        hour: '2-digit',
        minute: '2-digit',
        hour12: false,
        timeZone: tz,
      }).format(new Date());
    el.textContent = `SF ${fmt('America/Los_Angeles')} · AMS ${fmt('Europe/Amsterdam')}`;
  }
  renderClock();
  setInterval(renderClock, 30_000);
  document.addEventListener('astro:after-swap', renderClock);
</script>
