---
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  invertHeader?: boolean;
}

const {
  title = 'Gabri Ansaldo — Product Manager working on AI',
  description = 'Product Manager working on generative AI. Most recently at Motorola Solutions on a body-worn camera portfolio. Building multi-agent systems on the side. Based between San Francisco and Amsterdam.',
  image = '/images/gabri.jpg',
  invertHeader = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(image, Astro.site || Astro.url);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />

    <meta name="author" content="Gabri Ansaldo" />
    <meta name="theme-color" content="#F4F1EA" />
    <meta name="keywords" content="product manager, generative AI, AI agents, agentic systems, multi-agent, enterprise products, LLMs, San Francisco" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@300;400;500;600;700&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <ViewTransitions />
  </head>
  <body>
    <a href="#main" class="sr-only">Skip to main content</a>

    <header class:list={["site-header", invertHeader && "invert"]}>
      <div class="wrap site-header__inner">
        <a href="/" class="brand" aria-label="Gabri Ansaldo — home">
          <span class="brand-dot" aria-hidden="true"></span>
          <span>Gabri Ansaldo</span>
        </a>
        <nav class="nav" aria-label="Primary">
          <a href="/#work">Work</a>
          <a href="/#approach" data-secondary>Approach</a>
          <a href="/#contact">Contact</a>
        </nav>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="site-footer" id="contact">
      <div class="wrap">
        <div class="footer-grid">
          <div>
            <p class="eyebrow">Let's talk</p>
            <p class="footer-display">
              Building something at the<br />
              edge of <span class="serif-italic">AI &amp; product?</span>
            </p>
            <a href="mailto:ansaldo.gabri@gmail.com" class="footer-email">
              ansaldo.gabri@gmail.com
              <span class="arrow" aria-hidden="true">→</span>
            </a>
          </div>
          <div class="footer-side">
            <p class="eyebrow">Elsewhere</p>
            <ul class="footer-links">
              <li>
                <a href="https://www.linkedin.com/in/gabrieleansaldo/" target="_blank" rel="noopener noreferrer">
                  <span>LinkedIn</span>
                  <span class="arrow" aria-hidden="true">↗</span>
                </a>
              </li>
              <li>
                <a href="https://github.com/gabriansa" target="_blank" rel="noopener noreferrer">
                  <span>GitHub</span>
                  <span class="arrow" aria-hidden="true">↗</span>
                </a>
              </li>
              <li>
                <a href="mailto:ansaldo.gabri@gmail.com">
                  <span>Email</span>
                  <span class="arrow" aria-hidden="true">↗</span>
                </a>
              </li>
            </ul>
            <p class="footer-meta">
              San Francisco · Amsterdam
            </p>
          </div>
        </div>
        <div class="footer-bottom">
          <span>© {new Date().getFullYear()} Gabri Ansaldo</span>
          <span>Built with care · Astro &amp; Tailwind</span>
        </div>
      </div>
    </footer>

    <style>
      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }
      .sr-only:focus {
        position: fixed;
        top: 1rem;
        left: 1rem;
        width: auto;
        height: auto;
        padding: 0.75rem 1rem;
        background: var(--ink);
        color: var(--canvas);
        clip: auto;
        z-index: 100;
      }

      main {
        padding-top: 0;
      }

      /* Footer layout */
      .footer-grid {
        display: grid;
        grid-template-columns: 1.4fr 1fr;
        gap: 4rem;
        align-items: end;
        padding-bottom: 4rem;
        border-bottom: 1px solid var(--invert-hairline);
      }

      @media (max-width: 820px) {
        .footer-grid {
          grid-template-columns: 1fr;
          gap: 3rem;
        }
      }

      .footer-display {
        font-family: 'Instrument Serif', ui-serif, Georgia, serif;
        font-size: clamp(2.25rem, 6vw, 5rem);
        line-height: 1;
        margin: 1.4rem 0 2rem;
        letter-spacing: -0.02em;
      }

      .footer-email {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        font-family: 'Inter Tight', sans-serif;
        font-size: clamp(1.1rem, 1.6vw, 1.35rem);
        border-bottom: 1px solid color-mix(in srgb, var(--invert-text) 35%, transparent);
        padding-bottom: 0.35rem;
        transition: color 0.25s ease, border-color 0.25s ease;
      }

      .footer-email:hover {
        color: var(--accent);
        border-bottom-color: var(--accent);
      }

      .footer-email:hover .arrow {
        transform: translateX(4px);
      }

      .footer-email .arrow {
        display: inline-block;
        transition: transform 0.3s ease;
      }

      .footer-side .eyebrow {
        margin-bottom: 1.2rem;
      }

      .footer-links {
        list-style: none;
        padding: 0;
        margin: 0 0 2.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
      }

      .footer-links a {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 1rem;
        padding: 0.35rem 0;
        transition: color 0.25s ease, gap 0.25s ease;
      }

      .footer-links a:hover {
        color: var(--accent);
        gap: 0.85rem;
      }

      .footer-meta {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.78rem;
        line-height: 1.6;
        opacity: 0.6;
      }

      .footer-bottom {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 1.75rem;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.72rem;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        opacity: 0.55;
        gap: 1rem;
        flex-wrap: wrap;
      }
    </style>

    <script>
      const header = document.querySelector('.site-header');
      const onScroll = () => {
        if (!header) return;
        if (window.scrollY > 24) header.classList.add('is-scrolled');
        else header.classList.remove('is-scrolled');
      };
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });

      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -10% 0px' }
      );

      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

      document.addEventListener('astro:after-swap', () => {
        document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
      });
    </script>
  </body>
</html>
