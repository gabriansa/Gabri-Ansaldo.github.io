---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Marquee from '../components/Marquee.astro';
import WorkTile from '../components/WorkTile.astro';
import Stats from '../components/Stats.astro';
import Manifesto from '../components/Manifesto.astro';
import ExperienceList from '../components/ExperienceList.astro';
import Now from '../components/Now.astro';
import ContactCTA from '../components/ContactCTA.astro';
import Portrait from '../components/Portrait.astro';

const work = [
  {
    index: '01',
    title: 'Investi',
    tagline: 'An autonomous trading desk built from three agents that disagree productively. Researcher, Analyst, Trader—each with veto power.',
    href: 'https://tryinvesti.co',
    external: true,
    year: '2025',
    role: 'Founder & PM',
    tags: ['Multi-Agent', 'OpenAI Agents SDK', 'PostgreSQL · RAG', 'LangSmith', 'Alpaca'],
    visualLabel: 'Investi',
    visualAccent: 'accent' as const,
    size: 'lg' as const,
  },
  {
    index: '02',
    title: 'AgentSpeak',
    tagline: '100,000 simulated consumers, run before a single dollar of marketing spend. A market simulation framework for testing policy, pricing, and messaging.',
    href: '/work/agentspeak/',
    external: false,
    year: '2024',
    role: 'Author',
    tags: ['LangChain', 'LLMs', 'Statistical Eval', 'Python'],
    visualLabel: 'AgentSpeak',
    visualAccent: 'ink' as const,
  },
  {
    index: '03',
    title: 'Motorola · Edge AI Voice Tagging',
    tagline: 'Shipped voice tagging on body-worn cameras to 20+ enterprise police departments. 75% less data entry, even when the radio drops.',
    href: '/work/motorola-edge-ai/',
    external: false,
    year: '2024 — 2026',
    role: 'Product Manager',
    tags: ['Edge AI', 'Voice UX', 'Enterprise', 'C2PA'],
    visualLabel: 'Edge AI',
    visualAccent: 'canvas' as const,
  },
  {
    index: '04',
    title: 'Explicit Agent',
    tagline: 'Every tool call. Every state change. Visible. A minimal agent framework that refuses to hide what it is doing.',
    href: '/work/explicit-agent/',
    external: false,
    year: '2024',
    role: 'Author',
    tags: ['Open Source', 'LiteLLM', 'OpenRouter', 'Transparency'],
    visualLabel: 'Explicit',
    visualAccent: 'ink' as const,
  },
];

const stats = [
  { value: '$50M', label: 'ARR retained at Motorola through a 100+ customer migration', context: 'Enterprise · 90% retention' },
  { value: '75%', label: 'Reduction in officer data-entry time with Edge AI voice tagging', context: 'Voice UX · Offline-first' },
  { value: '100K', label: 'Synthetic consumers simulated before a marketing dollar moved', context: 'AgentSpeak · LLM personas' },
  { value: '95%', label: 'Accuracy on a human–robot collaboration task with multi-agent RL', context: 'Research · MAGICS Lab' },
];
---

<Layout
  title="Gabri Ansaldo — Product Manager working on AI"
  description="Product Manager working on generative AI. Most recently at Motorola Solutions on a body-worn camera portfolio. Building multi-agent systems on the side. Based between San Francisco and Amsterdam."
>
  <Hero />

  <Marquee
    items={[
      'AI Agents',
      'Multi-Agent Systems',
      'Generative AI',
      'Enterprise Product',
      'Evals &amp; Trust',
      'Voice UX',
      'Autonomous Systems',
    ]}
  />

  <section class="work" id="work">
    <div class="wrap">
      <div class="work__head reveal">
        <span class="eyebrow">Selected work — 2023 to today</span>
        <h2 class="work__title">
          A handful of projects<br />
          <span class="serif-italic">I'm proud of.</span>
        </h2>
        <p class="work__sub">
          Across enterprise software, autonomous agents, and open-source tools.
          Some shipped to thousands of users, some are still rough drafts.
        </p>
      </div>

      <div class="work__grid">
        {work.map((w) => <WorkTile {...w} />)}
      </div>
    </div>
  </section>

  <Stats items={stats} />

  <Portrait />

  <Manifesto />

  <ExperienceList />

  <Now />

  <ContactCTA />
</Layout>

<style>
  .work {
    padding: clamp(5rem, 9vw, 9rem) 0 clamp(3rem, 5vw, 5rem);
  }

  .work__head {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    margin-bottom: clamp(3rem, 6vw, 4.5rem);
    max-width: 38ch;
  }

  .work__title {
    font-family: 'Inter Tight', sans-serif;
    font-weight: 400;
    font-size: clamp(2.25rem, 5.5vw, 4.5rem);
    line-height: 1;
    letter-spacing: -0.035em;
    margin: 0;
  }

  .work__sub {
    color: var(--mute);
    font-size: clamp(1rem, 1.3vw, 1.15rem);
    line-height: 1.55;
    max-width: 52ch;
    margin: 0;
  }

  .work__grid {
    display: flex;
    flex-direction: column;
  }

  .work__grid :global(.work-tile:last-child) {
    border-bottom: 1px solid var(--hairline);
  }
</style>
