---
export interface StatItem {
  value: string;
  label: string;
  context: string;
}

export interface Props {
  items: StatItem[];
}

const { items } = Astro.props;
---

<section class="stats invert">
  <div class="wrap">
    <div class="stats__head reveal">
      <span class="eyebrow">By the numbers</span>
      <h2 class="stats__title">
        Outcomes, <span class="serif-italic">not output.</span>
      </h2>
    </div>
    <ul class="stats__grid">
      {items.map((item) => (
        <li class="stats__item reveal">
          <span class="stats__value">{item.value}</span>
          <span class="stats__label">{item.label}</span>
          <span class="stats__context">{item.context}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .stats {
    padding: clamp(5rem, 9vw, 9rem) 0;
  }

  .stats__head {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: clamp(3rem, 6vw, 5rem);
    max-width: 32ch;
  }

  .stats__title {
    font-family: 'Inter Tight', sans-serif;
    font-weight: 400;
    font-size: clamp(2.25rem, 5vw, 4rem);
    line-height: 1;
    letter-spacing: -0.03em;
    margin: 0;
  }

  .stats__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
  }

  @media (max-width: 980px) {
    .stats__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 540px) {
    .stats__grid {
      grid-template-columns: 1fr;
    }
  }

  .stats__item {
    padding: clamp(1.5rem, 3vw, 2.5rem) clamp(1rem, 2vw, 1.75rem);
    border-top: 1px solid var(--invert-hairline);
    border-right: 1px solid var(--invert-hairline);
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    min-height: clamp(220px, 22vw, 320px);
    justify-content: space-between;
  }

  .stats__item:last-child {
    border-right: none;
  }

  @media (max-width: 980px) {
    .stats__item:nth-child(2n) {
      border-right: none;
    }
  }

  @media (max-width: 540px) {
    .stats__item {
      border-right: none;
      min-height: auto;
    }
  }

  .stats__value {
    font-family: 'Instrument Serif', ui-serif, Georgia, serif;
    font-size: clamp(3.5rem, 9vw, 7.5rem);
    line-height: 0.9;
    letter-spacing: -0.04em;
    color: var(--accent);
  }

  .stats__label {
    font-family: 'Inter Tight', sans-serif;
    font-size: clamp(1.05rem, 1.4vw, 1.2rem);
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--invert-text);
  }

  .stats__context {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: color-mix(in srgb, var(--invert-text) 55%, transparent);
  }
</style>
