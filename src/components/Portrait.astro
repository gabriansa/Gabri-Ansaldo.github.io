---
---

<section class="portrait-band">
  <div class="wrap portrait-band__inner">
    <figure class="portrait reveal">
      <img
        src="/images/gabri.jpg"
        alt="Gabri Ansaldo"
        width="640"
        height="640"
        loading="lazy"
        decoding="async"
      />
      <figcaption class="portrait__cap">
        <span class="portrait__num">01 / 01</span>
        <span class="portrait__loc">Gabri Ansaldo · 2026</span>
      </figcaption>
    </figure>

    <div class="portrait-band__copy reveal">
      <span class="eyebrow">Hi, briefly</span>
      <p class="portrait-band__quote">
        I'm <span class="serif-italic">Gabri</span>—an Italian engineer who took the long way
        around: Groningen, Delft, Boston, San Francisco, now mostly between
        <span class="serif-italic">SF</span> and <span class="serif-italic">Amsterdam.</span>
      </p>
      <p class="portrait-band__sub">
        I spend my days thinking about how to ship AI products that hold up under
        real-world use—and my evenings building small ones to find out what that
        actually takes.
      </p>
    </div>
  </div>
</section>

<style>
  .portrait-band {
    padding: clamp(5rem, 9vw, 9rem) 0;
  }

  .portrait-band__inner {
    display: grid;
    grid-template-columns: minmax(260px, 1fr) 1.4fr;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: center;
  }

  @media (max-width: 820px) {
    .portrait-band__inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }

  .portrait {
    position: relative;
    margin: 0;
    max-width: 420px;
  }

  .portrait::before {
    content: '';
    position: absolute;
    inset: 18px -18px -18px 18px;
    background: var(--accent);
    border-radius: 4px;
    z-index: 0;
    transition: transform 0.5s cubic-bezier(0.2, 0.7, 0.1, 1);
  }

  .portrait:hover::before {
    transform: translate(-12px, -12px);
  }

  .portrait img {
    position: relative;
    z-index: 1;
    width: 100%;
    height: auto;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 4px;
    filter: grayscale(100%) contrast(1.05);
    transition: filter 0.6s ease;
    display: block;
  }

  .portrait:hover img {
    filter: grayscale(0%) contrast(1);
  }

  .portrait__cap {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 0.85rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--mute);
  }

  .portrait__num {
    color: var(--accent);
  }

  .portrait-band__copy {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
  }

  .portrait-band__quote {
    font-family: 'Inter Tight', sans-serif;
    font-weight: 400;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--ink);
    max-width: 26ch;
  }

  .portrait-band__sub {
    font-size: clamp(1rem, 1.3vw, 1.15rem);
    line-height: 1.55;
    color: var(--mute);
    max-width: 50ch;
    margin: 0;
  }
</style>
